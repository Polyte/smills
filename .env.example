# Copy to .env or .env.local for local dev (Vite reads both).
# API: https://supabase.com/dashboard/project/_/settings/api
#
# If VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY are missing or empty, the CRM
# uses SQLite in your browser (IndexedDB) instead — fine for demos or offline use.
# Optional: force SQLite even when Supabase vars are set:
# VITE_CRM_USE_SQLITE=true
#
# --- Local SQLite: optional dev auto-login (password is exposed in the browser bundle; dev only) ---
# When the CRM user table is empty, the app can create the first manager automatically:
#   • Runs on `npm run dev` by default, OR set VITE_CRM_AUTO_SEED_DEV_LOGINS=true (not for public sites).
# Optional second manager (created after the first; first user stays signed in).
# VITE_CRM_DEV_ADMIN_EMAIL=admin@standerton.local
# VITE_CRM_DEV_ADMIN_PASSWORD=changeme
# VITE_CRM_DEV_ADMIN_FULL_NAME=Standerton Admin
# VITE_CRM_DEV_ADMIN2_EMAIL=manager2@standerton.local
# VITE_CRM_DEV_ADMIN2_PASSWORD=changeme
# VITE_CRM_DEV_ADMIN2_FULL_NAME=Second Manager
# After the first account exists, add more logins in CRM → Settings (manager only).
#
# Removing all local logins (Settings) sets a browser flag so auto-seed does NOT run on the next reload.
# Use Settings → "Allow .env dev logins on next empty reload" to clear that flag, or complete first-time setup.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Timescale telemetry API (docker compose → automation-api on :4000). Uncomment for live machine charts.
VITE_AUTOMATION_API_URL=http://localhost:4000

# Only for npm run db:push — the Postgres password from:
# Dashboard → Project Settings → Database → Database password (NOT the anon key).
# SUPABASE_DB_PASSWORD=your-database-password

# --- RFID / workforce (server-side only; never put secrets in Vite env) ---
#
# On-site API (logs scans to Supabase via service role):
#   Dev:  npm run dev  →  http://localhost:3000  (app + POST /api/rfid on same port)
#   Prod: npm run api:rfid  →  default http://<host>:3001/api/rfid  (set RFID_API_PORT to change)
#   Header: Authorization: Bearer <RFID_DEVICE_SECRET>
#   Body:  { "readerKey": "<reader_key>", "rfidUid": "<card uid>" }
#
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# RFID_DEVICE_SECRET=long-random-string
# Optional: SUPABASE_URL=https://...  (defaults to VITE_SUPABASE_URL if set)
#
# Deploy Edge Function: supabase/functions/rfid-ingest
#   supabase secrets set RFID_DEVICE_SECRET="long-random-string"
# Arduino (HTTPS POST JSON):
#   URL:  https://<project-ref>.supabase.co/functions/v1/rfid-ingest
#   Header: Authorization: Bearer <same RFID_DEVICE_SECRET>
#   Body:  { "readerKey": "<access_readers.reader_key>", "rfidUid": "<card uid>" }
# Optional: "clientTs": "2026-03-29T12:00:00.000Z", "deviceMeta": { "firmware": "1.0" }
#
# Managers can also simulate scans from CRM (calls workforce_apply_access_event with their session).
# Apply migration: supabase/migrations/0003_workforce_attendance.sql

# --- Public quotes / PDF email (Edge Functions) ---
# Migration: supabase/migrations/0007_quotes_invoicing.sql
# Functions: submit-quote-request, send-commercial-document
# Secrets (Supabase Dashboard → Edge Functions → Secrets), or CLI:
#   supabase secrets set RESEND_API_KEY="re_..."
#   supabase secrets set RESEND_FROM="Standerton Mills <onboarding@resend.dev>"
#   supabase secrets set QUOTE_DEFAULT_OWNER_ID="<profiles.id uuid>"
# Optional: comma-separated inbox for quote alert emails (skips auth email lookup):
#   supabase secrets set QUOTE_NOTIFY_EMAIL="you@company.com,other@company.com"
# Optional link in quote emails:
#   supabase secrets set CRM_APP_URL="https://your-site.com"
# submit-quote-request validates Authorization: Bearer <VITE_SUPABASE_ANON_KEY>.
# send-commercial-document requires a signed-in CRM user (manager or employee JWT).
# (Do not put RESEND_API_KEY in Vite — it is only for Edge Functions.)
