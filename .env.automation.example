# Used by docker compose for automation-api (copy to .env or export before `docker compose up`).
# Timescale credentials match docker-compose defaults — change both if you customize the DB.

# Timescale connection (automation-api only). Docker Compose sets this inside the container by default.
# For npm run dev in services/automation-api, or any hosted Timescale/Tiger Cloud DB, set e.g.:
#   TIMESCALE_URL=postgres://user:pass@localhost:5433/factory_ts
#   TIMESCALE_URL=postgres://user:pass@your-host.tsdb.cloud:35668/tsdb?sslmode=require
# After provisioning, run services/automation-api/scripts/init-timescale.sql once against that DB.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: HMAC-less PLC ingest (set same value on devices).
# AUTOMATION_INGEST_SECRET=long-random-string

CORS_ORIGIN=http://localhost:5173
SIMULATOR_ENABLED=true
