# Used by docker compose for automation-api (copy to .env or export before `docker compose up`).
# Timescale credentials match docker-compose defaults — change both if you customize the DB.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: HMAC-less PLC ingest (set same value on devices).
# AUTOMATION_INGEST_SECRET=long-random-string

CORS_ORIGIN=http://localhost:5173
SIMULATOR_ENABLED=true
